# Database
DATABASE_URL=postgresql://rag:rag@postgres:5432/ragdb

# ChromaDB
CHROMA_URL=http://chroma:8000  # Use "embedded" for Render deployment
CHROMA_PERSIST_DIR=./chroma_data  # For embedded mode on Render
CHROMA_COLLECTION=documents

# LLM Provider (openai or ollama)
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production-use-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin Credentials (CHANGE IN PRODUCTION!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# File Upload Settings
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.pdf,.txt,.docx

# RAG Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=8
CHAT_HISTORY_LIMIT=5
